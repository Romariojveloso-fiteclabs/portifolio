---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.localeCompare(a.data.pubDate)
);

const categories = ['Todos', ...new Set(posts.map((post) => post.data.category))];
---

<Layout title="Roma Blog — Home">
	<div class="space-y-8">
		<!-- Hero Section -->
		<section class="py-12 border-b border-slate-200 dark:border-slate-800 text-center md:text-left">
			<h1 class="text-4xl md:text-5xl font-black tracking-tight text-slate-900 dark:text-white leading-none">
				Bem-vindo ao meu <span class="bg-gradient-to-r from-brand-500 to-brand-600 bg-clip-text text-transparent">Blog</span>
			</h1>
			<p class="mt-4 text-base md:text-lg text-slate-500 dark:text-slate-400 max-w-2xl leading-relaxed">
				Ideias, insights, projetos de engenharia eletrônica analógica e sistemas embarcados, desenvolvimento de software fullstack, além de tutoriais, artigos e publicações técnicas.
			</p>
		</section>

		<!-- Posts Grid -->
		<section class="space-y-6">
			<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 pb-4 border-b border-slate-100 dark:border-slate-800">
				<h2 class="text-xl font-bold tracking-tight text-slate-900 dark:text-white flex items-center gap-2">
					Artigos Recentes
				</h2>
				
				<div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
					<div class="flex flex-wrap gap-2" id="category-filters">
						{categories.map((category) => (
							<button
								class={`category-btn px-3 py-1.5 text-xs font-semibold rounded-full border transition-all ${
									category === 'Todos'
										? 'bg-brand-500 text-white border-brand-500 dark:bg-brand-600 dark:border-brand-600'
										: 'bg-white dark:bg-slate-950 text-slate-600 dark:text-slate-400 border-slate-200 dark:border-slate-800 hover:border-brand-500 hover:text-brand-500'
								}`}
								data-category={category}
							>
								{category}
							</button>
						))}
					</div>

					<div class="flex items-center gap-2">
						<label for="sort-select" class="text-xs font-medium text-slate-500 dark:text-slate-400 whitespace-nowrap">
							Ordenar por:
						</label>
						<select
							id="sort-select"
							class="bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg px-2.5 py-1.5 text-xs font-semibold text-slate-700 dark:text-slate-300 focus:outline-none focus:border-brand-500 transition-colors cursor-pointer"
						>
							<option value="recent">Mais recentes</option>
							<option value="oldest">Mais antigos</option>
						</select>
					</div>
				</div>
			</div>
			
			<div id="posts-grid" class="grid grid-cols-1 md:grid-cols-2 gap-6">
				{posts.map((post) => (
					<article 
						class="post-item group bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-2xl overflow-hidden hover:border-brand-500/50 shadow-sm hover:shadow transition-all flex flex-col"
						data-date={post.data.pubDate}
						data-category={post.data.category}
					>
						{post.data.image && (
							<div class="h-44 overflow-hidden relative">
								<img 
									src={post.data.image} 
									alt={post.data.title} 
									class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
								/>
								<span class="absolute top-3 left-3 px-2 py-0.5 text-[10px] font-bold bg-brand-500 text-white rounded">
									{post.data.category}
								</span>
							</div>
						)}
						<div class="p-5 flex flex-col flex-grow">
							<span class="text-xs font-mono font-medium text-slate-400 dark:text-slate-500">
								{post.data.pubDate} • {post.data.readTime} leitura
							</span>
							<h3 class="mt-2 text-lg font-bold text-slate-900 dark:text-white leading-snug group-hover:text-brand-500 transition-colors">
								<a href={`/blog/${post.slug}.html`}>{post.data.title}</a>
							</h3>
							<p class="mt-3 text-xs md:text-sm text-slate-500 dark:text-slate-400 line-clamp-3 leading-relaxed flex-grow">
								{post.data.description}
							</p>
							<div class="mt-5 pt-4 border-t border-slate-100 dark:border-slate-900/60 flex items-center justify-between text-xs font-bold text-brand-500">
								<a href={`/blog/${post.slug}.html`}>Ler artigo completo &rarr;</a>
							</div>
						</div>
					</article>
				))}
			</div>
		</section>
	</div>
</Layout>

<script>
	const grid = document.getElementById('posts-grid');
	const articles = Array.from(grid.querySelectorAll('.post-item'));
	const buttons = document.querySelectorAll('.category-btn');
	const sortSelect = document.getElementById('sort-select');

	let activeCategory = 'Todos';
	let activeSort = 'recent';

	function updateArticles() {
		const visibleArticles = articles.filter(article => {
			const category = article.getAttribute('data-category');
			return activeCategory === 'Todos' || category === activeCategory;
		});

		visibleArticles.sort((a, b) => {
			const dateA = a.getAttribute('data-date');
			const dateB = b.getAttribute('data-date');
			if (activeSort === 'recent') {
				return dateB.localeCompare(dateA);
			} else {
				return dateA.localeCompare(dateB);
			}
		});

		articles.forEach(article => {
			article.style.display = 'none';
		});

		visibleArticles.forEach(article => {
			article.style.display = 'flex';
			grid.appendChild(article);
		});
	}

	buttons.forEach(button => {
		button.addEventListener('click', () => {
			activeCategory = button.getAttribute('data-category');

			buttons.forEach(btn => {
				btn.classList.remove('bg-brand-500', 'text-white', 'border-brand-500', 'dark:bg-brand-600', 'dark:border-brand-600');
				btn.classList.add('bg-white', 'dark:bg-slate-950', 'text-slate-600', 'dark:text-slate-400', 'border-slate-200', 'dark:border-slate-800');
			});

			button.classList.add('bg-brand-500', 'text-white', 'border-brand-500', 'dark:bg-brand-600', 'dark:border-brand-600');
			button.classList.remove('bg-white', 'dark:bg-slate-950', 'text-slate-600', 'dark:text-slate-400', 'border-slate-200', 'dark:border-slate-800');

			updateArticles();
		});
	});

	sortSelect.addEventListener('change', (e) => {
		activeSort = e.target.value;
		updateArticles();
	});
</script>
