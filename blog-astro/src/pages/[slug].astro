---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={`${post.data.title} — Roma Blog`}>
	<article class="max-w-2xl mx-auto py-4">
		<!-- Back Button -->
		<a href="/blog/index.html" class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 dark:text-brand-400 hover:underline mb-8">
			&larr; Voltar para Artigos
		</a>

		<!-- Post header details -->
		<header class="mb-8">
			<div class="flex items-center gap-3 mb-3 text-xs md:text-sm text-slate-500 dark:text-slate-400 font-mono">
				<span class="px-2.5 py-0.5 text-xs font-bold bg-brand-100 dark:bg-brand-950/50 text-brand-700 dark:text-brand-300 rounded">
					{post.data.category}
				</span>
				<span>{post.data.pubDate}</span>
				<span>•</span>
				<span>{post.data.readTime} de leitura</span>
			</div>
			<h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-tight">
				{post.data.title}
			</h1>
		</header>

		{post.data.image && (
			<div class="w-full h-64 md:h-80 rounded-2xl overflow-hidden mb-8 border border-slate-200 dark:border-slate-800">
				<img 
					src={post.data.image} 
					alt={post.data.title} 
					class="w-full h-full object-cover"
				/>
			</div>
		)}

		<!-- Article Content Body -->
		<div class="prose prose-slate dark:prose-invert max-w-none text-slate-700 dark:text-slate-300 pb-12">
			<Content />
		</div>
	</article>
</Layout>
