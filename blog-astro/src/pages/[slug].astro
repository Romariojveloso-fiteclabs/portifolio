---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const siteUrl = 'https://romariojonas.com';
const postUrl = `${siteUrl}/blog/${post.slug}.html`;
const shareTitle = post.data.title;

// Limpar markdown e extrair os 3 primeiros parágrafos do corpo do post
const cleanBodyText = post.body
	.replace(/^#+\s+.+$/gm, '') // Remove títulos h1, h2, etc.
	.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1') // Remove links mantendo o texto do link
	.replace(/[\*_`~]/g, '') // Remove caracteres de formatação
	.trim();

const paragraphs = cleanBodyText
	.split(/\n\s*\n/)
	.map(p => p.trim())
	.filter(p => p.length > 0 && !p.startsWith('>'));

const shareSnippet = paragraphs.slice(0, 3).join('\n\n');

const maxSnippetChars = 1000;
const finalShareText = shareSnippet.length > maxSnippetChars
	? shareSnippet.slice(0, maxSnippetChars) + '...'
	: shareSnippet;
---

<Layout 
	title={`${post.data.title} — Roma Blog`}
	description={post.data.description}
	image={post.data.image}
>
	<article class="max-w-2xl mx-auto py-4">
		<!-- Back Button -->
		<a href="/blog/index.html" class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 dark:text-brand-400 hover:underline mb-8">
			&larr; Voltar para Artigos
		</a>

		<!-- Post header details -->
		<header class="mb-8">
			<div class="flex items-center gap-3 mb-3 text-xs md:text-sm text-slate-500 dark:text-slate-400 font-mono">
				<span class="px-2.5 py-0.5 text-xs font-bold bg-brand-100 dark:bg-brand-950/50 text-brand-700 dark:text-brand-300 rounded">
					{post.data.category}
				</span>
				<span>{post.data.pubDate}</span>
				<span>•</span>
				<span>{post.data.readTime} de leitura</span>
			</div>
			<h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-tight">
				{post.data.title}
			</h1>

			<!-- Share buttons top -->
			<div class="flex items-center gap-2 mt-5 pt-4 border-t border-slate-100 dark:border-slate-800/60">
				<span class="text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500 mr-1">Compartilhar:</span>
				<button id="open-share-modal" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold text-slate-700 dark:text-slate-200 bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 rounded-lg transition-colors cursor-pointer select-none">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.658-3.142m0 5.658l-5.658-3.142m0 0a3 3 0 110-2.278m0 2.278a3 3 0 110 2.278m0 0a3 3 0 100-2.278"/>
					</svg>
					Compartilhar Artigo
				</button>
			</div>
		</header>

		{post.data.image && (
			<div class="w-full h-64 md:h-80 rounded-2xl overflow-hidden mb-8 border border-slate-200 dark:border-slate-800">
				<img 
					src={post.data.image} 
					alt={post.data.title} 
					class="w-full h-full object-cover"
				/>
			</div>
		)}

		<!-- Article Content Body -->
		<div class="prose prose-slate dark:prose-invert max-w-none text-slate-700 dark:text-slate-300 pb-8">
			<Content />
		</div>

		<!-- Share buttons bottom -->
		<div class="mt-8 pt-6 border-t border-slate-200 dark:border-slate-800 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 pb-12">
			<div class="flex items-center gap-2">
				<span class="text-sm font-bold text-slate-600 dark:text-slate-400">Gostou do texto? Compartilhe:</span>
				<button id="open-share-modal-bottom" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold text-slate-700 dark:text-slate-200 bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 rounded-lg transition-colors cursor-pointer select-none">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l5.658-3.142m0 5.658l-5.658-3.142m0 0a3 3 0 110-2.278m0 2.278a3 3 0 110 2.278m0 0a3 3 0 100-2.278"/>
					</svg>
					Compartilhar Artigo
				</button>
			</div>
		</div>
	</article>
</Layout>

<!-- Modal de Compartilhamento -->
<div 
	id="share-modal" 
	class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-xs transition-opacity duration-300 opacity-0"
	data-url={postUrl}
	data-title={shareTitle}
	data-description={finalShareText}
>
	<div 
		id="share-modal-content" 
		class="bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-2xl max-w-md w-full mx-4 overflow-hidden shadow-2xl transform scale-95 opacity-0 transition-all duration-300"
	>
		<!-- Header do modal -->
		<div class="px-5 py-4 border-b border-slate-100 dark:border-slate-900/60 flex items-center justify-between">
			<h3 class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider font-mono">Compartilhar Artigo</h3>
			<button id="close-share-modal" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors p-1 cursor-pointer">
				<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
				</svg>
			</button>
		</div>

		<!-- Card Preview -->
		<div class="p-5">
			<div class="border border-slate-200 dark:border-slate-800/80 rounded-xl overflow-hidden bg-slate-50 dark:bg-slate-900/40 p-4">
				{post.data.image && (
					<div class="h-40 w-full overflow-hidden rounded-lg mb-3 border border-slate-200/60 dark:border-slate-800/60">
						<img src={post.data.image} alt="" class="w-full h-full object-cover" />
					</div>
				)}
				<h4 class="text-sm font-bold text-slate-900 dark:text-white leading-snug">
					{post.data.title}
				</h4>
				<p class="mt-2 text-xs text-slate-500 dark:text-slate-400 line-clamp-4 leading-relaxed">
					{finalShareText}
				</p>
				<div class="mt-3 pt-3 border-t border-slate-200/60 dark:border-slate-800/60 text-[10px] font-mono text-brand-600 dark:text-brand-400 font-bold truncate">
					Leia mais em: {postUrl}
				</div>
			</div>
		</div>

		<!-- Ações / Footer -->
		<div class="px-5 py-4 bg-slate-50 dark:bg-slate-900/20 border-t border-slate-100 dark:border-slate-900/60 flex items-center justify-end">
			<button id="copy-share-card" class="w-full inline-flex items-center justify-center gap-1.5 px-4 py-2 text-xs font-bold text-white bg-brand-600 hover:bg-brand-700 rounded-xl transition-colors cursor-pointer select-none shadow-sm font-sans">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/>
				</svg>
				<span id="copy-btn-text">Copiar Texto de Compartilhamento</span>
			</button>
		</div>
	</div>
</div>

<script>
	const modal = document.getElementById('share-modal');
	const content = document.getElementById('share-modal-content');
	const openBtn = document.getElementById('open-share-modal');
	const openBtnBottom = document.getElementById('open-share-modal-bottom');
	const closeBtn = document.getElementById('close-share-modal');
	const copyBtn = document.getElementById('copy-share-card');
	const copyBtnText = document.getElementById('copy-btn-text');

	const openModal = () => {
		if (modal && content) {
			modal.classList.remove('hidden');
			modal.classList.add('flex');
			document.body.classList.add('overflow-hidden');
			setTimeout(() => {
				modal.classList.add('opacity-100');
				content.classList.remove('scale-95', 'opacity-0');
				content.classList.add('scale-100', 'opacity-100');
			}, 10);
		}
	};

	const closeModal = () => {
		if (modal && content) {
			modal.classList.remove('opacity-100');
			content.classList.remove('scale-100', 'opacity-100');
			content.classList.add('scale-95', 'opacity-0');
			document.body.classList.remove('overflow-hidden');
			setTimeout(() => {
				modal.classList.remove('flex');
				modal.classList.add('hidden');
			}, 300);
		}
	};

	openBtn?.addEventListener('click', openModal);
	openBtnBottom?.addEventListener('click', openModal);
	closeBtn?.addEventListener('click', closeModal);
	
	modal?.addEventListener('click', (e) => {
		if (e.target === modal) {
			closeModal();
		}
	});

	copyBtn?.addEventListener('click', () => {
		if (modal && copyBtn && copyBtnText) {
			const url = modal.getAttribute('data-url') || '';
			const title = modal.getAttribute('data-title') || '';
			const description = modal.getAttribute('data-description') || '';
			
			const textToCopy = `${title}\n\n${description}\n\nLeia mais em:\n${url}`;

			navigator.clipboard.writeText(textToCopy).then(() => {
				copyBtnText.textContent = 'Texto copiado!';
				copyBtn.classList.remove('bg-brand-600', 'hover:bg-brand-700');
				copyBtn.classList.add('bg-green-600');

				setTimeout(() => {
					copyBtnText.textContent = 'Copiar Texto de Compartilhamento';
					copyBtn.classList.remove('bg-green-600');
					copyBtn.classList.add('bg-brand-600', 'hover:bg-brand-700');
				}, 2000);
			}).catch(err => {
				console.error('Erro ao copiar:', err);
			});
		}
	});
</script>
