---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout 
	title={`${post.data.title} — Roma Blog`}
	description={post.data.description}
	image={post.data.image}
>
	<article class="max-w-2xl mx-auto py-4">
		<!-- Back Button -->
		<a href="/blog/index.html" class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 dark:text-brand-400 hover:underline mb-8">
			&larr; Voltar para Artigos
		</a>

		<!-- Post header details -->
		<header class="mb-8">
			<div class="flex items-center gap-3 mb-3 text-xs md:text-sm text-slate-500 dark:text-slate-400 font-mono">
				<span class="px-2.5 py-0.5 text-xs font-bold bg-brand-100 dark:bg-brand-950/50 text-brand-700 dark:text-brand-300 rounded">
					{post.data.category}
				</span>
				<span>{post.data.pubDate}</span>
				<span>•</span>
				<span>{post.data.readTime} de leitura</span>
			</div>
			<h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-tight">
				{post.data.title}
			</h1>

			<!-- Share buttons top -->
			<div class="flex items-center gap-2 mt-5 pt-4 border-t border-slate-100 dark:border-slate-800/60">
				<span class="text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500 mr-1">Compartilhar:</span>
				<button id="share-linkedin" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold text-white bg-[#0077b5] hover:bg-[#006297] rounded-lg transition-colors cursor-pointer select-none">
					<svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
						<path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
					</svg>
					LinkedIn
				</button>
				<button id="share-whatsapp" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold text-white bg-[#25d366] hover:bg-[#20ba56] rounded-lg transition-colors cursor-pointer select-none">
					<svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
						<path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.42 9.863-9.864.001-2.637-1.03-5.115-2.905-6.99C16.559 1.876 14.077.846 11.437.846 6.002.846 1.577 5.271 1.574 10.707c-.001 1.678.437 3.31 1.266 4.772L1.877 20.2l4.77-1.046zM18.006 14.5c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.669.149-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.501-.669-.51l-.57-.011c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
					</svg>
					WhatsApp
				</button>
			</div>
		</header>

		{post.data.image && (
			<div class="w-full h-64 md:h-80 rounded-2xl overflow-hidden mb-8 border border-slate-200 dark:border-slate-800">
				<img 
					src={post.data.image} 
					alt={post.data.title} 
					class="w-full h-full object-cover"
				/>
			</div>
		)}

		<!-- Article Content Body -->
		<div class="prose prose-slate dark:prose-invert max-w-none text-slate-700 dark:text-slate-300 pb-8">
			<Content />
		</div>

		<!-- Share buttons bottom -->
		<div class="mt-8 pt-6 border-t border-slate-200 dark:border-slate-800 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 pb-12">
			<div class="flex items-center gap-2">
				<span class="text-sm font-bold text-slate-600 dark:text-slate-400">Gostou do texto? Compartilhe:</span>
				<button id="share-linkedin-bottom" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold text-white bg-[#0077b5] hover:bg-[#006297] rounded-lg transition-colors cursor-pointer select-none">
					<svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
						<path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
					</svg>
					LinkedIn
				</button>
				<button id="share-whatsapp-bottom" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold text-white bg-[#25d366] hover:bg-[#20ba56] rounded-lg transition-colors cursor-pointer select-none">
					<svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
						<path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.42 9.863-9.864.001-2.637-1.03-5.115-2.905-6.99C16.559 1.876 14.077.846 11.437.846 6.002.846 1.577 5.271 1.574 10.707c-.001 1.678.437 3.31 1.266 4.772L1.877 20.2l4.77-1.046zM18.006 14.5c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.669.149-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.501-.669-.51l-.57-.011c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
					</svg>
					WhatsApp
				</button>
			</div>
		</div>
	</article>
</Layout>

<script>
	let url = window.location.href;
	if (!url.includes('romariojonas.com')) {
		url = url.replace(/https?:\/\/[^\/]+/, 'https://romariojonas.com');
	}
	const title = document.title;

	const shareLinkedIn = () => {
		window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`, '_blank');
	};

	const shareWhatsApp = () => {
		window.open(`https://api.whatsapp.com/send?text=${encodeURIComponent(title)}%20${encodeURIComponent(url)}`, '_blank');
	};

	document.getElementById('share-linkedin')?.addEventListener('click', shareLinkedIn);
	document.getElementById('share-linkedin-bottom')?.addEventListener('click', shareLinkedIn);
	document.getElementById('share-whatsapp')?.addEventListener('click', shareWhatsApp);
	document.getElementById('share-whatsapp-bottom')?.addEventListener('click', shareWhatsApp);
</script>
