---
import BlogFilters from './BlogFilters.astro';
import PostCard from './PostCard.astro';

interface Props {
	posts: any[];
	categories: string[];
}

const { posts, categories } = Astro.props;
---

<section class="space-y-6">
	<BlogFilters categories={categories} />
	
	<div id="posts-grid" class="grid grid-cols-1 md:grid-cols-2 gap-6">
		{posts.map((post) => (
			<PostCard post={post} />
		))}
	</div>
</section>

<script>
	const grid = document.getElementById('posts-grid');
	if (grid) {
		const articles = Array.from(grid.querySelectorAll('.post-item'));
		const buttons = document.querySelectorAll('.category-btn');
		const sortSelect = document.getElementById('sort-select');

		let activeCategory = 'Todos';
		let activeSort = 'recent';

		const updateArticles = () => {
			const visibleArticles = articles.filter(article => {
				const category = article.getAttribute('data-category');
				return activeCategory === 'Todos' || category === activeCategory;
			});

			visibleArticles.sort((a, b) => {
				const dateA = a.getAttribute('data-date') || '';
				const dateB = b.getAttribute('data-date') || '';
				if (activeSort === 'recent') {
					return dateB.localeCompare(dateA);
				} else {
					return dateA.localeCompare(dateB);
				}
			});

			articles.forEach(article => {
				(article as HTMLElement).style.display = 'none';
			});

			visibleArticles.forEach(article => {
				(article as HTMLElement).style.display = 'flex';
				grid.appendChild(article);
			});
		};

		buttons.forEach(button => {
			button.addEventListener('click', () => {
				activeCategory = button.getAttribute('data-category') || 'Todos';

				buttons.forEach(btn => {
					btn.classList.remove('bg-brand-500', 'text-white', 'border-brand-500', 'dark:bg-brand-600', 'dark:border-brand-600');
					btn.classList.add('bg-white', 'dark:bg-slate-950', 'text-slate-600', 'dark:text-slate-400', 'border-slate-200', 'dark:border-slate-800');
				});

				button.classList.add('bg-brand-500', 'text-white', 'border-brand-500', 'dark:bg-brand-600', 'dark:border-brand-600');
				button.classList.remove('bg-white', 'dark:bg-slate-950', 'text-slate-600', 'dark:text-slate-400', 'border-slate-200', 'dark:border-slate-800');

				updateArticles();
			});
		});

		if (sortSelect) {
			sortSelect.addEventListener('change', (e) => {
				const target = e.target as HTMLSelectElement;
				activeSort = target.value;
				updateArticles();
			});
		}
	}
</script>
